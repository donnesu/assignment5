#!/bin/bash

if (( $# < 2 )); then
  echo "kubectl appshow <kind> <instance>"
  exit 0
fi

kind=$1
instance=$2
namespace=$instance

if ! kubectl get "$kind" "$instance" >/dev/null 2>&1; then
  echo "Instance $instance does not exist for Kind $kind."
  exit 0
fi

pod=$(kubectl get pods -n "$namespace" -o jsonpath='{.items[0].metadata.name}')
deployment=$(kubectl get deployments -n "$namespace" -o jsonpath='{.items[0].metadata.name}')
configmap=$(kubectl get configmaps -n "$namespace" -o jsonpath='{.items[?(@.metadata.name!="kube-root-ca.crt")].metadata.name}')
serviceaccount=$(kubectl get serviceaccounts -n "$namespace" -o jsonpath='{.items[?(@.metadata.name!="default")].metadata.name}')
networkpolicy=$(kubectl get networkpolicies -n "$namespace" -o jsonpath='{.items[0].metadata.name}')

cat <<EOF
{
  "pod": "$pod",
  "deployment": "$deployment",
  "configmap": "$configmap",
  "serviceaccount": "$serviceaccount",
  "networkpolicy": "$networkpolicy"
}
EOF
